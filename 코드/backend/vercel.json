{
  "buildCommand": "npm install",
  "installCommand": "npm install",
  "framework": "express",
  "version": 2,
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "app.js"
    }
  ],
  "functions": {
    "app.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 60
    }
  }
}